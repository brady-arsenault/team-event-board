generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String  @id
  email        String  @unique
  displayName  String
  role         String
  passwordHash String

  events Event[] @relation("EventOrganizer")
  rsvps  Rsvp[]
}

model Event {
  id          String   @id
  title       String
  description String
  location    String
  category    String
  capacity    Int?
  status      String
  startAt     DateTime
  endAt       DateTime
  organizerId String
  createdAt   DateTime
  updatedAt   DateTime

  organizer User   @relation("EventOrganizer", fields: [organizerId], references: [id])
  rsvps     Rsvp[]

  @@index([status, startAt])
}

model Rsvp {
  id        String   @id
  eventId   String
  userId    String
  status    String
  createdAt DateTime
  updatedAt DateTime

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
}
