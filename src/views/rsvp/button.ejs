<div id="rsvp-widget">
  <% const isGoing = rsvp && rsvp.status === "going"; %>
  <% const isWaitlisted = rsvp && rsvp.status === "waitlisted"; %>
  <% const isActive = isGoing || isWaitlisted; %>

  <div class="inline-flex items-center gap-2">
    <% if (isGoing) { %>
      <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700 border border-green-200">
        Going
      </span>
    <% } else if (isWaitlisted) { %>
      <span class="inline-flex items-center rounded-full bg-yellow-100 px-3 py-1 text-xs font-medium text-yellow-700 border border-yellow-200">
        Waitlisted
      </span>
    <% } %>

    <form
      method="post"
      action="/events/<%= eventId %>/rsvp"
      hx-post="/events/<%= eventId %>/rsvp"
      hx-target="#rsvp-widget"
      hx-swap="outerHTML"
      class="m-0"
    >
      <% if (isActive) { %>
        <button
          type="submit"
          class="inline-flex items-center px-4 py-2 rounded-2xl border border-red-200 text-red-700 text-sm font-medium hover:bg-red-50 cursor-pointer"
        >
          Cancel RSVP
        </button>
      <% } else { %>
        <button
          type="submit"
          class="inline-flex items-center px-4 py-2 rounded-2xl bg-green-600 text-white text-sm font-semibold hover:bg-green-700 cursor-pointer"
        >
          RSVP
        </button>
      <% } %>
    </form>
  </div>
</div>
