<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <h2 class="text-xl font-semibold text-slate-900 mb-4">Past &amp; Cancelled</h2>

  <% if (past.length === 0) { %>
    <p class="text-slate-500 m-0">
      No past or cancelled RSVPs yet.
    </p>
  <% } else { %>
    <ul class="list-none p-0 m-0 space-y-3">
      <% past.forEach(function (item) { %>
        <li class="p-4 border border-slate-200 rounded-xl bg-slate-50 opacity-75">
          <h3 class="text-lg font-semibold text-slate-700 mb-1">
            <%= item.event.title %>
          </h3>
          <p class="text-sm text-slate-500 mb-1">
            <%= item.event.startAt.toLocaleString() %> &middot; <%= item.event.location %>
          </p>
          <span class="inline-block text-xs font-medium px-2 py-1 rounded-full bg-slate-200 text-slate-700">
            <%= item.rsvp.status === "cancelled" ? "cancelled" : item.event.status %>
          </span>
        </li>
      <% }); %>
    </ul>
  <% } %>
</section>
