<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-2">My RSVPs</h1>
  <p class="text-slate-500 m-0">
    Events you have responded to, grouped into upcoming and past.
  </p>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<div id="my-rsvps-content">
  <%- include("partials/dashboard-content", { upcoming: upcoming, past: past }) %>
</div>
