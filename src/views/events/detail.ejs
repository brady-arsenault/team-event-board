<section class="max-w-3xl mx-auto p-6 border border-slate-200 rounded-3xl bg-white shadow-lg">
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-900"><%= event.title %></h1>
      <p class="text-sm text-slate-500 mt-1">
        <span class="font-medium text-slate-700"><%= event.category %></span>
        ·
        <span><%= event.location %></span>
      </p>
    </div>
    <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600 border border-slate-200 shrink-0">
      <%= event.status %>
    </span>
  </div>

  <% if (pageError) { %>
    <%- include("../partials/error", { message: pageError }) %>
  <% } %>

  <div class="space-y-5">
    <div>
      <h2 class="text-sm font-medium text-slate-700 mb-1">Description</h2>
      <p class="text-slate-600 leading-relaxed"><%= event.description %></p>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
        <p class="text-xs font-medium text-slate-500 mb-1">Starts</p>
        <p class="text-sm font-semibold text-slate-900"><%= event.startAt.toLocaleString() %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
        <p class="text-xs font-medium text-slate-500 mb-1">Ends</p>
        <p class="text-sm font-semibold text-slate-900"><%= event.endAt.toLocaleString() %></p>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
        <p class="text-xs font-medium text-slate-500 mb-1">Organizer</p>
        <p class="text-sm font-semibold text-slate-900"><%= event.organizerId %></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
        <p class="text-xs font-medium text-slate-500 mb-1">Capacity</p>
        <p class="text-sm font-semibold text-slate-900">
          <% if (event.capacity !== null) { %>
            <%= event.capacity %> spots
          <% } else { %>
            Unlimited
          <% } %>
        </p>
      </div>
    </div>

    <div class="flex items-center justify-between pt-2">
      <a
        href="/home"
        class="inline-flex items-center px-4 py-2 rounded-2xl border border-slate-200 text-slate-700 text-sm font-medium hover:bg-slate-50"
      >
        &larr; Back to Events
      </a>

      <div class="flex items-center gap-3">
        <div id="rsvp-widget"
          hx-get="/events/<%= event.id %>/rsvp"
          hx-trigger="load"
          hx-swap="outerHTML"
        ></div>

        <% if (session.authenticatedUser && session.authenticatedUser.userId === event.organizerId) { %>
          <a
            href="/events/edit/<%= event.id %>"
            class="inline-flex items-center px-4 py-2 rounded-2xl bg-blue-600 text-white text-sm font-semibold hover:bg-blue-700"
          >
            Edit Event
          </a>
        <% } %>
      </div>
    </div>
  </div>
</section>
