<section class="max-w-3xl mx-auto p-6 border border-slate-200 rounded-3xl bg-white shadow-lg">
  <h1 class="text-2xl font-bold text-slate-900 mb-4">Edit Event</h1>

  <div id="error-slot">
    <% if (message) { %>
      <%- include("partials/error", { message: message }) %>
    <% } %>
  </div>

  <form
    hx-post="/events/edit/<%= event.id %>"
    hx-target="#error-slot"
    hx-swap="innerHTML"
    class="space-y-5"
    
  >
    <div>
      <label for="title" class="block text-sm font-medium text-slate-700 mb-2">Title</label>
      <input
        id="title"
        name="title"
        type="text"
        required
        value="<%= event.title %>"
        class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-blue-500"
      />
    </div>

    <div>
      <label for="description" class="block text-sm font-medium text-slate-700 mb-2">Description</label>
      <textarea
        id="description"
        name="description"
        rows="4"
        required
        class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-blue-500"
      ><%= event.description %></textarea>
    </div>

    <div>
      <label for="location" class="block text-sm font-medium text-slate-700 mb-2">Location</label>
      <input
        id="location"
        name="location"
        type="text"
        required
        value="<%= event.location %>"
        class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-blue-500"
      />
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
      <div>
        <label for="category" class="block text-sm font-medium text-slate-700 mb-2">Category</label>
        <select
          id="category"
          name="category"
          required
          class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-blue-500"
        >
          <option value="social" <%= event.category === "social" ? "selected" : "" %>>Social</option>
          <option value="educational" <%= event.category === "educational" ? "selected" : "" %>>Educational</option>
          <option value="volunteer" <%= event.category === "volunteer" ? "selected" : "" %>>Volunteer</option>
          <option value="sports" <%= event.category === "sports" ? "selected" : "" %>>Sports</option>
          <option value="arts" <%= event.category === "arts" ? "selected" : "" %>>Arts</option>
          <option value="other" <%= event.category === "other" ? "selected" : "" %>>Other</option>
        </select>
      </div>

      <div>
        <label for="capacity" class="block text-sm font-medium text-slate-700 mb-2">Capacity</label>
        <input
          id="capacity"
          name="capacity"
          type="number"
          min="1"
          placeholder="Leave blank for no limit"
          value="<%= event.capacity === null ? "" : event.capacity %>"
          class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-blue-500"
        />
      </div>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
      <div>
        <label for="startAt" class="block text-sm font-medium text-slate-700 mb-2">Start date</label>
        <input
          id="startAt"
          name="startAt"
          type="datetime-local"
          required
          value="<%= event.startAt instanceof Date ? event.startAt.toISOString().slice(0, 16) : new Date(event.startAt).toISOString().slice(0, 16) %>"
          class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-blue-500"
        />
      </div>

      <div>
        <label for="endAt" class="block text-sm font-medium text-slate-700 mb-2">End date</label>
        <input
          id="endAt"
          name="endAt"
          type="datetime-local"
          required
          value="<%= event.endAt instanceof Date ? event.endAt.toISOString().slice(0, 16) : new Date(event.endAt).toISOString().slice(0, 16) %>"
          class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none focus:border-blue-500"
        />
      </div>
    </div>

    <div class="flex justify-end">
      <button
        type="submit"
        class="inline-flex items-center justify-center rounded-2xl bg-blue-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-blue-700"
      >
        Save Changes
      </button>
    </div>
  </form>
</section>
